          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/products?page=1&limit=10&category=electronics",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "products"],
              "query": [
